import os
import re
import json
import base64
import subprocess
from IPython.display import Audio, display, HTML, clear_output

def karaoke_totalmente_automatico():
    # 1. ENTRADA DE DATOS
    print("--- 🎤 CONFIGURACIÓN DEL ESCENARIO ---")
    cancion = input("🎵 Nombre de la canción: ")
    artista = input("🎤 Nombre del artista: ")

    if not cancion or not artista:
        print("⚠️ Introduce los datos necesarios.")
        return

    clear_output(wait=True)
    print(f"🚀 Preparando escenario para: {cancion}...")

    try:
        # 2. DESCARGA DE RITMO (Instrumental)
        import syncedlyrics
        audio_file = "karaoke_final.mp3"
        if os.path.exists(audio_file): os.remove(audio_file)

        # Búsqueda ultra-específica para evitar voces
        query = f"ytsearch1:{cancion} {artista} karaoke instrumental version"
        print("🎸 Descargando pista instrumental...")
        subprocess.run([
            "yt-dlp", "-x", "--audio-format", "mp3",
            "--audio-quality", "0", "-o", audio_file, query
        ], capture_output=True)

        if not os.path.exists(audio_file):
            print("❌ No se pudo descargar el ritmo.")
            return

        # 3. OBTENER Y PARSEAR LETRA
        print("📡 Sincronizando letras...")
        lrc_data = syncedlyrics.search(f"{cancion} {artista}", providers=['lrclib'])
        if not lrc_data:
            print("❌ No hay letra sincronizada disponible.")
            return

        # Convertimos la letra LRC a un formato que Javascript entienda (JSON)
        lyrics_list = []
        for line in lrc_data.split('\n'):
            match = re.search(r'\[(\d+):(\d+\.\d+)\](.*)', line)
            if match:
                time_sec = int(match.group(1)) * 60 + float(match.group(2))
                text = match.group(3).strip()
                if text: lyrics_list.append({'time': time_sec, 'text': text})

        lyrics_json = json.dumps(lyrics_list)

        # 4. CARGAR AUDIO EN MEMORIA (Para que funcione sin rutas de archivo raras)
        with open(audio_file, "rb") as f:
            audio_base64 = base64.b64encode(f.read()).decode('utf-8')
        audio_src = f"data:audio/mp3;base64,{audio_base64}"

        # 5. GENERAR INTERFAZ HTML + JAVASCRIPT (Sincronización Automática)
        clear_output()
        html_code = f"""
        <div style="background-color: #121212; padding: 30px; border-radius: 20px; border: 4px solid #1DB954; text-align: center; font-family: sans-serif;">
            <h2 style="color: #1DB954; margin-bottom: 10px;">{cancion.upper()}</h2>
            <p style="color: #B3B3B3; margin-bottom: 20px;">{artista}</p>

            <audio id="karaoke-audio" controls style="width: 100%; margin-bottom: 20px;">
                <source src="{audio_src}" type="audio/mp3">
            </audio>

            <div style="min-height: 150px; display: flex; flex-direction: column; justify-content: center; background: #000; border-radius: 15px; padding: 20px;">
                <h1 id="active-lyric" style="color: white; font-size: 35px; margin: 0;">¡Dale al Play!</h1>
                <p id="next-lyric" style="color: #535353; font-size: 18px; margin-top: 15px;"></p>
            </div>
        </div>

        <script>
            (function() {{
                const lyrics = {lyrics_json};
                const audio = document.getElementById('karaoke-audio');
                const textDisplay = document.getElementById('active-lyric');
                const nextDisplay = document.getElementById('next-lyric');

                audio.ontimeupdate = () => {{
                    const currentTime = audio.currentTime;
                    let activeIdx = -1;

                    for (let i = 0; i < lyrics.length; i++) {{
                        if (currentTime >= lyrics[i].time) {{
                            activeIdx = i;
                        }} else {{
                            break;
                        }}
                    }}

                    if (activeIdx !== -1) {{
                        textDisplay.innerText = lyrics[activeIdx].text;
                        if (lyrics[activeIdx + 1]) {{
                            nextDisplay.innerText = "Siguiente: " + lyrics[activeIdx + 1].text;
                        }} else {{
                            nextDisplay.innerText = "";
                        }}
                    }}
                }};
            }})();
        </script>
        """
        display(HTML(html_code))

    except Exception as e:
        print(f"⚠️ Error: {e}")

# Ejecutar el Karaoke Automático
karaoke_totalmente_automatico()
